# Set to 'production' on the server — enforces WEBHOOK_TOKEN on the platform webhook
NODE_ENV=
PORT=5005
MONGO_URI=mongodb://127.0.0.1:27017/pcp-affiliates
JWT_SECRET=change-me
# Optional: shared ingest key (affiliates then pass lead_source in body)
SHARED_API_KEY=
# REQUIRED in production: token on the platform webhook (?token=)
WEBHOOK_TOKEN=

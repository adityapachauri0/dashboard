# Set to 'production' on the server — enforces WEBHOOK_TOKEN on the platform webhook
NODE_ENV=
PORT=5005
MONGO_URI=mongodb://127.0.0.1:27017/pcp-affiliates
JWT_SECRET=change-me
# Optional: shared ingest key (affiliates then pass lead_source in body)
SHARED_API_KEY=
# REQUIRED in production: token on the platform webhook (?token=)
WEBHOOK_TOKEN=
# BlueLion invoicing — accounts mailbox used to send invoices/recons
ACCOUNTS_SMTP_HOST=smtpout.secureserver.net
ACCOUNTS_SMTP_PORT=465
ACCOUNTS_SMTP_USER=accounts@click2leads.co.uk
ACCOUNTS_SMTP_PASS=
# Recipient pending client
INVOICE_TO_EMAIL=
INVOICE_CC=
# Rates default in code (110/30) — set here only to override
BLUELION_VIRGIN_RATE=110
BLUELION_SEARCHED_RATE=30
# Optional: pinged after a clean daily invoice run
INVOICE_HEARTBEAT_URL=
